float calculateHeatIndex(float T, float H) {
    const float c1 = -42.379;
    const float c2 = 2.04901523;
    const float c3 = 10.14333127;
    const float c4 = -0.22475541;
    const float c5 = -0.00683783;
    const float c6 = -0.05481717;
    const float c7 = 0.00122874;
    const float c8 = 0.00085282;
    const float c9 = -0.00000199;

    float HI = c1 + c2*T + c3*H + c4*T*H + c5*T*T + c6*H*H + c7*T*T*H + c8*T*H*H + c9*T*T*H*H;

    // Heat index adjustment conditions
    if ((H < 13) && (T >= 80.0) && (T <= 112.0)) {
        HI -= ((13 - H) / 4.0f) * sqrt((17 - fabs(T - 95.0f)) / 17.0f);
    }

    if ((H > 85) && (T >= 80.0) && (T <= 87.0)) {
        HI += ((H - 85) / 10.0f) * ((87.0f - T) / 5.0f);
    }

    return HI;
}





